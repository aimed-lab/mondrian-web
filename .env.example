# =============================================================================
# Mondrian Map — local development environment variables
#
# Copy this file to .env and fill in your values.
# .env is in .gitignore — it will NEVER be committed to the repository.
#
# Production values are set in:
#   Netlify Dashboard → Project → Project Configuration → Environment variables
# =============================================================================

# Required: Your OpenAI API key.
# Only read server-side (Vite dev middleware / Netlify Function).
# This variable does NOT have the VITE_ prefix, so Vite never injects it
# into the browser bundle. It is completely safe from client-side exposure.
OPENAI_API_KEY=sk-...your-key-here...

# Optional: Override the model used for AI explanations.
# Defaults to gpt-5.4-nano if not set.
OPENAI_MODEL=gpt-5.4-nano

# Optional: Set to "true" to print the full assembled prompt to the terminal
# before each API call. Useful for reviewing prompt quality during development.
# Prompts are always logged when NODE_ENV=development (i.e. `vite dev`).
LOG_PROMPTS=true
